{
  "name": "@agentspec/sdk",
  "version": "0.1.3",
  "description": "AgentSpec SDK — load, validate, health-check, audit, and generate from agent.yaml",
  "author": "Sallah Kokaina <sallah.kokaina@gmail.com>",
  "license": "Apache-2.0",
  "homepage": "https://agentspec.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/agents-oss/agentspec.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/agents-oss/agentspec/issues"
  },
  "keywords": [
    "ai-agents",
    "agent-manifest",
    "llm",
    "owasp-llm-top10",
    "langgraph",
    "mcp",
    "compliance",
    "health-checks"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./schemas/v1/agent.schema.json": "./schemas/v1/agent.schema.json"
  },
  "files": [
    "dist",
    "schemas"
  ],
  "scripts": {
    "prebuild": "rm -rf schemas && cp -r ../../schemas schemas",
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.17.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
