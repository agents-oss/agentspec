{
  "name": "@agentspec/cli",
  "version": "0.1.0",
  "description": "AgentSpec CLI — validate, health, audit, generate, init",
  "type": "module",
  "bin": {
    "agentspec": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
