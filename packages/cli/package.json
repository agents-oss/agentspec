    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@agentspec/sdk": "workspace:*",
    "@agentspec/adapter-claude": "workspace:*",
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "@clack/prompts": "^0.9.1",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.17.0",
    "execa": "^9.5.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
