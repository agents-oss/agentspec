{
  "name": "@agentspec/cli",
  "version": "0.1.11",
  "description": "AgentSpec CLI — validate, health, audit, generate, init",
  "author": "Sallah Kokaina <sallah.kokaina@gmail.com>",
  "license": "Apache-2.0",
  "homepage": "https://agentspec.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/agents-oss/agentspec.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/agents-oss/agentspec/issues"
  },
  "keywords": [
    "ai-agents",
    "agent-manifest",
    "llm",
    "cli",
    "agentspec"
  ],
  "type": "module",
  "bin": {
    "agentspec": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
