{
  "name": "@agentspec/adapter-claude",
  "version": "0.1.10",
  "description": "AgentSpec agentic adapter — uses Claude API to generate complete agent code from agent.yaml",
  "author": "Sallah Kokaina <sallah.kokaina@gmail.com>",
  "license": "Apache-2.0",
  "homepage": "https://agentspec.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/agents-oss/agentspec.git",
    "directory": "packages/adapter-claude"
  },
  "bugs": {
    "url": "https://github.com/agents-oss/agentspec/issues"
  },
  "keywords": [
    "ai-agents",
    "agent-manifest",
    "claude",
    "anthropic",
    "agentspec",
    "code-generation"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && mkdir -p dist/skills && cp src/skills/*.md dist/skills/",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@agentspec/sdk": "workspace:*",
    "@anthropic-ai/sdk": "^0.36.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
